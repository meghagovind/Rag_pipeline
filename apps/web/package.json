{
  "name": "rag-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file=../../.env node_modules/next/dist/bin/next dev",
    "build": "node --env-file=../../.env node_modules/next/dist/bin/next build",
    "start": "node --env-file=../../.env node_modules/next/dist/bin/next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate --schema=../../prisma/schema.prisma"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@vercel/blob": "^2.5.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.0",
    "react-markdown": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "8.5.10",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.0"
  },
  "overrides": {
    "postcss": "$postcss",
    "undici": "6.27.0"
  }
}
