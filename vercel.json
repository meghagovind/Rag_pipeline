{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": "apps/web/",
      "framework": "nextjs",
      "installCommand": "npm install",
      "buildCommand": "npm run build",
      "outputDirectory": ".next",
      "bindings": [
        {
          "type": "service",
          "service": "ingestion",
          "format": "url",
          "env": "INGESTION_API_URL"
        }
      ]
    },
    "ingestion": {
      "root": "services/ingestion/",
      "framework": "fastapi",
      "entrypoint": "main:app",
      "installCommand": "pip install -r requirements.txt"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": { "service": "web" }
    }
  ]
}
