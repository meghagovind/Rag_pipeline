# ──────────────────────────────────────────────────
# Database (Neon Postgres)
# ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require

# ──────────────────────────────────────────────────
# Blob / File Storage
# ──────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# ──────────────────────────────────────────────────
# Ingestion Service
# ──────────────────────────────────────────────────
INGESTION_API_URL=http://localhost:8000

# ──────────────────────────────────────────────────
# LLM (Ollama or HuggingFace-compatible endpoint)
# ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral
EMBED_MODEL=BAAI/bge-small-en-v1.5

# ──────────────────────────────────────────────────
# Vercel Deployment
# ──────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
